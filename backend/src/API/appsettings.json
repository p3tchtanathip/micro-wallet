{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_HOST;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD",
    "Redis": "YOUR_REDIS_URL"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_REAL_SECRET_KEY_ON_SERVER",
    "Issuer": "MicroWallet",
    "Audience": "MicroWalletUsers",
    "ExpiryMinutes": 15
  },
  "FrontendUrl": "http://localhost:3000"
}